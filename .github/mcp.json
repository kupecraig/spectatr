{
  "mcpServers": {
    "mui": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@mui/mcp@latest"],
      "tools": ["*"]
    },    
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["@upstash/context7-mcp@1.0.31"],
      "env": {
        "CONTEXT7_API_KEY": "${{ secrets.CONTEXT7_API_KEY }}"
      },
      "tools": ["*"]
    }
  }
}