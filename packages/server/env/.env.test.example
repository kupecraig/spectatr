# Test Environment Configuration
# Copy this file to .env.test and update values as needed

# Node environment
NODE_ENV=test

# Database connection string — use the spectatr_app role so RLS is enforced
# This validates tenant isolation at the DB level, not just the application layer
DATABASE_URL=postgresql://spectatr_app:spectatr_app@localhost:5432/spectatr

# Redis connection (for BullMQ — not used in most tests)
REDIS_HOST=localhost
REDIS_PORT=6379

# Clerk Authentication — fake keys, never used in tests (mocked with vi.mock)
CLERK_PUBLISHABLE_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder

# Server port (unused in tests — no HTTP server started)
PORT=3001

# CORS allowed origin (unused in tests)
FRONTEND_URL=http://localhost:5173
